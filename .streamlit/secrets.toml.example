# ============================================================================
# MODELO de segredos — NÃO coloque valores reais aqui neste arquivo de exemplo.
# ============================================================================
# Os valores REAIS vão em:
#   • Streamlit Community Cloud: menu do app -> "Settings" -> "Secrets"
#   • (Opcional, para rodar no PC) copie este arquivo para
#     ".streamlit/secrets.toml" e preencha — esse arquivo NÃO vai para o GitHub.
#
# Onde pegar as chaves do Supabase:
#   Painel do projeto -> ícone de engrenagem (Settings) -> "API"
#   - "Project URL"        -> vai em url
#   - chave "service_role" (secreta!) -> vai em service_key
# ----------------------------------------------------------------------------

[supabase]
url = "https://SEU-PROJETO.supabase.co"
service_key = "COLE_AQUI_A_CHAVE_SERVICE_ROLE"

# Admins iniciais: criados automaticamente na 1ª vez (se ainda não existirem).
# Depois disso, dá para trocar a senha pela tela "Gerenciar Usuários".
[[admin_inicial]]
usuario = "Hudson"
nome = "Hudson Steel"
senha = "ESCOLHA_UMA_SENHA_FORTE"

[[admin_inicial]]
usuario = "Reginaldo"
nome = "Reginaldo Jeronimo"
senha = "ESCOLHA_UMA_SENHA_FORTE"
